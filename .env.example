NEXT_PUBLIC_POSTAL_CODE=V3A4S8
SUPABASE_URL=
SUPABASE_ANON_KEY=

# LLM provider — pick one of: anthropic (default) | groq | openrouter
# Only the API key for the active provider needs to be filled in.
LLM_PROVIDER=anthropic
LLM_MODEL=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Vision model for receipt parsing (optional — defaults to LLM_PROVIDER, then anthropic)
# Requires ANTHROPIC_API_KEY if LLM_VISION_PROVIDER=anthropic (the default).
LLM_VISION_PROVIDER=
LLM_VISION_MODEL=

CRON_SECRET=
